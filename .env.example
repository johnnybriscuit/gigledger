# ============================================================================
# BOZZY ENVIRONMENT VARIABLES - EXAMPLE FILE
# ============================================================================
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to version control - it contains secrets!
#
# IMPORTANT SECURITY NOTES:
# - Only EXPO_PUBLIC_* variables are bundled into the client app
# - Server-side secrets (RESEND_API_KEY, STRIPE_SECRET_KEY, etc.) should
#   NEVER be referenced in client code - use Supabase Edge Functions instead
# - See SECURITY_NOTES.md for detailed guidance
# ============================================================================

# ----------------------------------------------------------------------------
# SUPABASE CONFIGURATION (Client-side - OK to bundle)
# ----------------------------------------------------------------------------
# Get these from: https://app.supabase.com/project/_/settings/api
EXPO_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.your-anon-key-here

# ----------------------------------------------------------------------------
# SITE URL (Client-side - OK to bundle)
# ----------------------------------------------------------------------------
# Required for OAuth redirects and magic links
# Production: https://bozzygigs.com
# Local dev: http://localhost:8090
EXPO_PUBLIC_SITE_URL=http://localhost:8090

# ----------------------------------------------------------------------------
# EAS PROJECT ID (Client-side - OK to bundle)
# ----------------------------------------------------------------------------
# Set automatically by `eas init`
EXPO_PUBLIC_EAS_PROJECT_ID=your-eas-project-id

# ----------------------------------------------------------------------------
# GOOGLE MAPS API KEY (Client-side - OK to bundle IF RESTRICTED)
# ----------------------------------------------------------------------------
# Get from: https://console.cloud.google.com/apis/credentials
# CRITICAL: Restrict this key in Google Cloud Console to:
#   - HTTP referrers (for web): https://yourdomain.com/*
#   - iOS bundle ID: com.yourcompany.bozzy
#   - Android package name: com.yourcompany.bozzy
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=AIzaSyXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ----------------------------------------------------------------------------
# GOOGLE OAUTH (Client-side - OK to bundle)
# ----------------------------------------------------------------------------
# Set to 'true' to enable Google SSO button
# Requires Google OAuth client configured in Supabase
EXPO_PUBLIC_GOOGLE_OAUTH_ENABLED=false

# ----------------------------------------------------------------------------
# TAX CALCULATION CONFIGURATION (Client-side - OK to bundle)
# ----------------------------------------------------------------------------
EXPO_PUBLIC_TAX_YEAR=2025
EXPO_PUBLIC_FEDERAL_FLAT_RATE_SINGLE=0.12
EXPO_PUBLIC_FEDERAL_FLAT_RATE_MARRIED=0.12
EXPO_PUBLIC_FEDERAL_FLAT_RATE_HOH=0.12
EXPO_PUBLIC_USE_FEDERAL_BRACKETS=false

# ----------------------------------------------------------------------------
# STRIPE CONFIGURATION (Production - Server-side only)
# ----------------------------------------------------------------------------
# Get these from: https://dashboard.stripe.com/apikeys (Live Mode)
# WARNING: These are server-side secrets - NEVER reference in client code!
# Used only in Vercel API routes (api/create-checkout.ts, etc.)
STRIPE_SECRET_KEY_PROD=sk_live_your_stripe_secret_key_here
STRIPE_WEBHOOK_SECRET_PROD=whsec_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Stripe Price IDs (Client-side - OK to bundle)
# Get these from: https://dashboard.stripe.com/products (Live Mode)
EXPO_PUBLIC_STRIPE_MONTHLY_PRICE_ID_PROD=price_XXXXXXXXXXXXXXXXXXXXXXXX
EXPO_PUBLIC_STRIPE_YEARLY_PRICE_ID_PROD=price_XXXXXXXXXXXXXXXXXXXXXXXX

# ----------------------------------------------------------------------------
# RESEND API KEY (Server-side only - NEVER in client code!)
# ----------------------------------------------------------------------------
# Get from: https://resend.com/api-keys
# WARNING: This must ONLY be used in Supabase Edge Functions
# Add this to Supabase Edge Function secrets, NOT to client env vars:
#   supabase secrets set RESEND_API_KEY=re_xxxxx
# RESEND_API_KEY=re_XXXXXXXXXXXXXXXXXXXXXXXX
# RESEND_DOMAIN=resend.dev

# ----------------------------------------------------------------------------
# SUPABASE SERVICE ROLE KEY (Server-side only - NEVER in client code!)
# ----------------------------------------------------------------------------
# Get from: https://app.supabase.com/project/_/settings/api
# WARNING: This has admin privileges - NEVER expose to client!
# Used only in Vercel API routes for admin operations
# SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.your-service-role-key-here

# ----------------------------------------------------------------------------
# APP URL (Client-side - OK to bundle)
# ----------------------------------------------------------------------------
# For shareable invoice links
# Development: http://localhost:8081
# Production: https://gigledger-ten.vercel.app
NEXT_PUBLIC_APP_URL=http://localhost:8081
