{
  "name": "bozzy",
  "version": "1.0.0",
  "main": "index.ts",
  "description": "Self-employed musician income and tax tracking",
  "scripts": {
    "start": "expo start",
    "start:web": "EXPO_DEBUG=1 npx expo start --web --clear --host localhost --port 8090",
    "start:ios": "npx expo start --clear --host localhost",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "test": "vitest",
    "test:watch": "vitest --watch",
    "test:coverage": "vitest --coverage",
    "test:ui": "vitest --ui",
    "verify:tax-treatment": "tsx scripts/verify-tax-treatment-exports.ts",
    "scan:secrets": "tsx scripts/scan-secrets.ts",
    "typecheck": "tsc --noEmit",
    "supabase:types": "supabase gen types typescript --local > src/types/database.types.ts",
    "lint": "eslint src --ext .ts,.tsx",
    "lint:fix": "eslint src --ext .ts,.tsx --fix",
    "lint:design-system": "eslint src/screens src/components --ext .ts,.tsx",
    "build:web": "npm run build:expo && npm run inject:gtm",
    "build:expo": "npx expo export --platform web",
    "inject:gtm": "node inject-gtm.js",
    "build:ios:dev": "eas build --profile development --platform ios",
    "build:ios:preview": "eas build --profile preview --platform ios",
    "build:ios:prod": "eas build --profile production --platform ios",
    "build:android:dev": "eas build --profile development --platform android",
    "build:android:preview": "eas build --profile preview --platform android",
    "build:android:prod": "eas build --profile production --platform android",
    "ios:device:register": "eas device:create",
    "ios:build:dev": "eas build --platform ios --profile development-device",
    "ios:run:dev": "npx expo start --dev-client --clear",
    "ios:build:testflight": "eas build --platform ios --profile production",
    "ios:submit:testflight": "eas submit --platform ios --profile production --latest"
  },
  "overrides": {
    "react-simple-maps": {
      "react": "$react"
    }
  },
  "dependencies": {
    "@floating-ui/react": "^0.27.16",
    "@phosphor-icons/react": "^2.1.10",
    "@react-native-google-signin/google-signin": "^16.1.1",
    "@react-navigation/native": "^6.1.9",
    "@react-navigation/native-stack": "^6.9.17",
    "@stripe/stripe-js": "^8.3.0",
    "@supabase/supabase-js": "^2.39.0",
    "@tanstack/react-query": "^5.17.0",
    "bcryptjs": "^2.4.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "d3-scale": "^4.0.2",
    "date-fns": "^4.1.0",
    "expo": "~54.0.33",
    "expo-auth-session": "^7.0.10",
    "expo-calendar": "^55.0.9",
    "expo-clipboard": "~8.0.8",
    "expo-constants": "~18.0.9",
    "expo-crypto": "~15.0.1",
    "expo-dev-client": "~6.0.20",
    "expo-document-picker": "~14.0.8",
    "expo-file-system": "~19.0.21",
    "expo-image-picker": "~17.0.10",
    "expo-linear-gradient": "^55.0.8",
    "expo-linking": "~8.0.11",
    "expo-print": "~15.0.8",
    "expo-secure-store": "~15.0.8",
    "expo-sharing": "~14.0.8",
    "expo-status-bar": "~3.0.9",
    "expo-web-browser": "~15.0.10",
    "jszip": "^3.10.1",
    "nativewind": "^4.0.1",
    "otpauth": "^9.2.2",
    "pdf-lib": "^1.17.1",
    "phosphor-react-native": "^3.0.3",
    "prop-types": "^15.8.1",
    "qrcode": "^1.5.3",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-joyride": "^2.9.3",
    "react-native": "0.81.5",
    "react-native-get-random-values": "^1.11.0",
    "react-native-google-places-textinput": "^0.9.1",
    "react-native-qrcode-svg": "^6.3.2",
    "react-native-safe-area-context": "5.6.2",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "^15.12.1",
    "react-native-url-polyfill": "^2.0.0",
    "react-native-web": "^0.21.0",
    "react-native-webview": "13.15.0",
    "react-simple-maps": "^3.0.0",
    "recharts": "^3.3.0",
    "stripe": "^19.3.0",
    "tailwind-merge": "^3.4.0",
    "topojson-client": "^3.1.0",
    "tslib": "^2.8.1",
    "victory": "^37.3.6",
    "victory-native": "^41.20.1",
    "xlsx": "^0.18.5",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/d3-scale": "^4.0.9",
    "@types/jest": "^30.0.0",
    "@types/qrcode": "^1.5.5",
    "@types/react": "~19.1.0",
    "@types/react-dom": "^19.2.3",
    "@types/react-simple-maps": "^3.0.6",
    "@types/topojson-client": "^3.1.5",
    "@typescript-eslint/eslint-plugin": "^8.47.0",
    "@typescript-eslint/parser": "^8.47.0",
    "@vercel/node": "^5.5.4",
    "@vitest/ui": "^2.1.8",
    "babel-preset-expo": "^54.0.4",
    "eslint": "^9.39.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-native": "^5.0.0",
    "jest": "^30.2.0",
    "tailwindcss": "^3.4.1",
    "ts-jest": "^29.4.5",
    "tsx": "^4.19.2",
    "typescript": "~5.9.2",
    "vitest": "^2.1.8"
  },
  "engines": {
    "node": "22.x"
  },
  "private": true
}
